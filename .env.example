# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sighd_user
MYSQL_PASSWORD=ChangeMe_StrongPassword123!

# --- JWT compartido por todos los servicios ---
JWT_SECRET=CAMBIAR_ESTE_SECRETO_LARGO_Y_UNICO_SIGHD_2026_CAMBIAR_ESTE_SECRETO_LARGO_Y_UNICO

# --- Auth service ---
AUTH_URL=http://localhost:8081
AUTH_SERVICE_URL=http://localhost:8081
AUTH_SERVICE_PORT=8081
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Admin123!
BOOTSTRAP_ADMIN_ROLE=ADMIN

# --- Pacientes ---
MS_PACIENTES_URL=http://localhost:8082
